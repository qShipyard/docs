  "keyFeatures": [
    "Reads git commits and generates audience-specific changelogs (developers, product, marketing, executives)",
    "Human approval step before any content is published",
    "Bring-your-own-AI: Anthropic Claude, OpenAI GPT-4o, Ollama (local), Groq, or custom endpoints",
    "Connect GitHub, GitLab, and Bitbucket via Personal Access Token — no OAuth app required",
    "Deliver approved drafts to Slack, Notion, Discord, Linear, email, or Markdown files",
    "Extensible plugin system (TypeScript) for sources, AI providers, and outputs",
    "Self-hosted — your code, your data, your infrastructure",
    "Real-time scan progress via WebSocket",
    "Configurable scan cadence: weekly schedule, on tag, on merge, or manual",
    "8-stage pipeline with noise filtering, PR enrichment, and deep codebase context (Rust reader)"
  ],
  "publicApiSurface": [
    "GET /api/v1/repos",
    "POST /api/v1/repos",
    "PATCH /api/v1/repos/:id",
    "DELETE /api/v1/repos/:id",
    "GET /api/v1/scans",
    "POST /api/v1/scans",
    "GET /api/v1/scans/:id",
    "GET /api/v1/scans/:id/commits",
    "GET /api/v1/scans/:id/groups",
    "GET /api/v1/scans/:id/drafts",
    "POST /api/v1/scans/:id/deliver",
    "PATCH /api/v1/drafts/:id",
    "POST /api/v1/drafts/:id/approve",
    "POST /api/v1/drafts/:id/reject",
    "POST /api/v1/drafts/:id/regenerate",
    "GET /api/v1/drafts/:id/comments",
    "POST /api/v1/drafts/:id/comments",
    "GET /api/v1/team/members",
    "POST /api/v1/team/invite",
    "POST /webhooks/github",
    "POST /webhooks/gitlab",
    "POST /webhooks/bitbucket",
    "GET /health",
    "WS /ws/scans/:id",
    "SourcePlugin.fetch(request: SourceRequest): Promise<SourceResponse>",
    "AIProviderPlugin.summarize(request: SummarizeRequest): Promise<SummarizeResponse>",
    "AIProviderPlugin.generate(request: GenerateRequest): Promise<GenerateResponse>",
    "OutputPlugin.deliver(request: DeliverRequest): Promise<DeliverResponse>",
    "runPlugin(plugin) — @narratorlog/sdk",
    "getFinalContent(request) — @narratorlog/sdk",
    "narratorlog create-plugin --type=output --name=<name>"
  ]
